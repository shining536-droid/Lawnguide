        },
        {
          "step": 2,
          "title": "공단 심사·결정",
          "description": "업무상 재해 여부 + 유족 자격 확인."
        },
        {
          "step": 3,
          "title": "지급",
          "description": "유족연금 (평균임금 × 일정율) 또는 일시금. 장의비 별도 지급."
        }
      ]
    }
