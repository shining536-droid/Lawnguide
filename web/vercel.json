{
  "framework": "nextjs",
  "buildCommand": "NODE_OPTIONS='--max-old-space-size=4096' npm run build",
  "outputDirectory": ".next",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "lawnguide.co.kr"
        }
      ],
      "destination": "https://www.lawnguide.co.kr/:path",
      "permanent": true
    }
  ]
}
